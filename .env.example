# Google Gemini API anahtarınızı buraya yazın.
# Bu dosyayı .env olarak kopyalayıp anahtarınızı ekleyin:
# cp .env.example .env
# Sonra .env dosyasında GEMINI_API_KEY=buraya_anahtarinizi_yazin

GEMINI_API_KEY=your_api_key_here

# İsteğe bağlı: tek model (örn. gemini-2.5-flash). Boş bırakılırsa varsayılan kullanılır.
# GEMINI_MODEL=gemini-2.5-flash

# İsteğe bağlı: virgülle ayrılmış yedek modeller (kota hariç hatalarda sırayla denenir).
# GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash
